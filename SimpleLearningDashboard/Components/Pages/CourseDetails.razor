@page "/course/{Id:int}"

@using SimpleLearningDashboard.Models
@using SimpleLearningDashboard.Services

@inject CourseStorageService Storage
@inject UserSession UserSession
@inject NavigationManager Nav

<h3 class="mb-4">Course Details</h3>

@if (string.IsNullOrEmpty(UserSession.Email))
{
    <p class="text-danger">Please log in first.</p>
}
else if (course == null)
{
    <p class="text-danger">Course not found.</p>

    <button class="btn btn-secondary mt-3"
            @onclick="GoBack">
        Back to Courses
    </button>
}
else
{
    <div class="card shadow p-4 mb-4">

        <h4 class="mb-2 fw-bold">
            <i class="bi bi-journal-text me-2"></i>@course.Name
        </h4>


        @if (course.IsCompleted)
        {
            <span class="badge bg-success mb-2">Completed</span>
        }

        <p class="mt-3">
            Lessons completed:
            <strong>@CompletedLessons / @course.Lessons.Count</strong>
        </p>

        <div class="progress mb-3" style="height: 18px;">
            <div class="progress-bar bg-success"
                 style="width:@Progress%">
                @Progress%
            </div>
        </div>

        <h5 class="mt-4">
            <i class="bi bi-list-check me-2"></i>Lessons
        </h5>


        @if (course.Lessons.Count == 0)
        {
            <p class="text-muted">No lessons added yet.</p>
        }
        else
        {
            <ul class="list-group mb-3">
                @foreach (var lesson in course.Lessons)
                {
                    <li class="list-group-item">
                        <input type="checkbox"
                               class="form-check-input me-2"
                               checked="@lesson.Completed"
                               disabled />
                        @lesson.Name
                    </li>
                }
            </ul>
        }

        <button class="btn btn-secondary"
                @onclick="GoBack">
            Back to Courses
        </button>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    Course? course;
    int CompletedLessons;
    int Progress;

    protected override void OnParametersSet()
    {
        // 🔐 Safety check
        if (string.IsNullOrEmpty(UserSession.Email))
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        var allCourses = Storage.Load();

        course = allCourses
            .FirstOrDefault(c =>
                c.Id == Id &&
                c.UserEmail == UserSession.Email);

        if (course != null)
        {
            CompletedLessons = course.Lessons.Count(l => l.Completed);

            Progress = course.Lessons.Count == 0
                ? 0
                : (CompletedLessons * 100) / course.Lessons.Count;
        }
    }

    void GoBack()
    {
        Nav.NavigateTo("/courses");
    }
}
